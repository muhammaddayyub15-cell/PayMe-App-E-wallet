{
  "name": "2FA — TOTP",
  "item": [
    {
      "name": "2FA Setup — Generate QR",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Accept", "value": "application/json" }
        ],
        "url": { "raw": "{{base_url}}/2fa/setup", "host": ["{{base_url}}"], "path": ["2fa", "setup"] },
        "body": { "mode": "raw", "raw": "{}" }
      }
    },
    {
      "name": "2FA Confirm — Aktifkan 2FA",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Accept", "value": "application/json" }
        ],
        "url": { "raw": "{{base_url}}/2fa/confirm", "host": ["{{base_url}}"], "path": ["2fa", "confirm"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"code\": \"123456\"\n}"
        }
      }
    },
    {
      "name": "2FA Verify Login — Step 2 Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Accept", "value": "application/json" }
        ],
        "url": { "raw": "{{base_url}}/2fa/verify-totp", "host": ["{{base_url}}"], "path": ["2fa", "verify-totp"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"code\": \"123456\"\n}"
        }
      }
    },
    {
      "name": "2FA Verify Login — Kode Salah (422)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Accept", "value": "application/json" }
        ],
        "url": { "raw": "{{base_url}}/2fa/verify-totp", "host": ["{{base_url}}"], "path": ["2fa", "verify-totp"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"code\": \"000000\"\n}"
        }
      }
    },
    {
      "name": "2FA Disable — Matikan 2FA",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Accept", "value": "application/json" }
        ],
        "url": { "raw": "{{base_url}}/2fa/disable", "host": ["{{base_url}}"], "path": ["2fa", "disable"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"password\": \"Passw0rd!23\"\n}"
        }
      }
    },
    {
      "name": "2FA Disable — Password Salah (422)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Accept", "value": "application/json" }
        ],
        "url": { "raw": "{{base_url}}/2fa/disable", "host": ["{{base_url}}"], "path": ["2fa", "disable"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"password\": \"WrongPass!\"\n}"
        }
      }
    }
  ]
},
{
  "name": "OTP — Transfer",
  "item": [
    {
      "name": "OTP Send — Kirim Kode ke Email",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Accept", "value": "application/json" }
        ],
        "url": { "raw": "{{base_url}}/otp/send", "host": ["{{base_url}}"], "path": ["otp", "send"] },
        "body": { "mode": "raw", "raw": "{}" }
      }
    },
    {
      "name": "OTP Verify — Kode Valid",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Accept", "value": "application/json" }
        ],
        "url": { "raw": "{{base_url}}/otp/verify", "host": ["{{base_url}}"], "path": ["otp", "verify"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"code\": \"123456\"\n}"
        }
      }
    },
    {
      "name": "OTP Verify — Kode Salah (422)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Accept", "value": "application/json" }
        ],
        "url": { "raw": "{{base_url}}/otp/verify", "host": ["{{base_url}}"], "path": ["otp", "verify"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"code\": \"000000\"\n}"
        }
      }
    },
    {
      "name": "OTP Verify — Kode Expired (422)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Accept", "value": "application/json" }
        ],
        "url": { "raw": "{{base_url}}/otp/verify", "host": ["{{base_url}}"], "path": ["otp", "verify"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"code\": \"123456\"\n}"
        }
      }
    },
    {
      "name": "Transfer — Tanpa OTP (403 otp_required)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Accept", "value": "application/json" },
          { "key": "X-Idempotency-Key", "value": "uuid-otp-test-001" }
        ],
        "url": { "raw": "{{base_url}}/transfer", "host": ["{{base_url}}"], "path": ["transfer"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"receiver_identifier\": \"ani@example.com\",\n  \"amount\": 25000\n}"
        }
      }
    },
    {
      "name": "Transfer — Setelah OTP Verified (Grace Period)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Accept", "value": "application/json" },
          { "key": "X-Idempotency-Key", "value": "uuid-otp-test-002" }
        ],
        "url": { "raw": "{{base_url}}/transfer", "host": ["{{base_url}}"], "path": ["transfer"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"receiver_identifier\": \"ani@example.com\",\n  \"amount\": 25000\n}"
        }
      }
    }
  ]
}